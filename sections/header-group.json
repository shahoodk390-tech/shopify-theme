      "settings": {
        "custom_liquid": "{% comment %} Scrolling Circular Collections Marquee {% endcomment %}\n\n<style>\n  .collections-marquee-wrapper {\n    overflow: hidden;\n    width: 100%;\n    padding: 20px 0;\n    background: #fff;\n  }\n  .collections-marquee-wrapper h2 {\n    text-align: center;\n    margin-bottom: 20px;\n    font-size: 1.5rem;\n    font-weight: 600;\n  }\n  .marquee-track {\n    display: flex;\n    width: max-content;\n    animation: marquee-scroll 20s linear infinite;\n  }\n  .marquee-track:hover {\n    animation-play-state: paused;\n  }\n  .marquee-item {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    margin: 0 20px;\n    text-decoration: none;\n    color: inherit;\n    min-width: 120px;\n  }\n  .marquee-circle {\n    width: 100px;\n    height: 100px;\n    border-radius: 50%;\n    overflow: hidden;\n    border: 3px solid #e0e0e0;\n    transition: border-color 0.3s;\n  }\n  .marquee-circle:hover {\n    border-color: #008060;\n  }\n  .marquee-circle img {\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n    display: block;\n  }\n  .marquee-circle-placeholder {\n    width: 100%;\n    height: 100%;\n    background: #f0f0f0;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-size: 2rem;\n    color: #aaa;\n  }\n  .marquee-label {\n    margin-top: 8px;\n    font-size: 0.8rem;\n    text-align: center;\n    max-width: 110px;\n    white-space: nowrap;\n    overflow: hidden;\n    text-overflow: ellipsis;\n  }\n  @keyframes marquee-scroll {\n    0%   { transform: translateX(0); }\n    100% { transform: translateX(-50%); }\n  }\n</style>\n\n<div class=\"collections-marquee-wrapper\">\n  <h2>Shop by Category</h2>\n  <div class=\"marquee-track\">\n    {% assign all_collections = collections | where: 'published', true %}\n    {% for collection in collections %}\n      <a class=\"marquee-item\" href=\"{{ collection.url }}\">\n        <div class=\"marquee-circle\">\n          {% if collection.image %}\n            <img src=\"{{ collection.image | image_url: width: 200 }}\" alt=\"{{ collection.title | escape }}\" loading=\"lazy\">\n          {% else %}\n            <div class=\"marquee-circle-placeholder\">🛍️</div>\n          {% endif %}\n        </div>\n        <span class=\"marquee-label\">{{ collection.title }}</span>\n      </a>\n    {% endfor %}\n    {% comment %} Duplicate for seamless loop {% endcomment %}\n    {% for collection in collections %}\n      <a class=\"marquee-item\" href=\"{{ collection.url }}\">\n        <div class=\"marquee-circle\">\n          {% if collection.image %}\n            <img src=\"{{ collection.image | image_url: width: 200 }}\" alt=\"{{ collection.title | escape }}\" loading=\"lazy\">\n          {% else %}\n            <div class=\"marquee-circle-placeholder\">🛍️</div>\n          {% endif %}\n        </div>\n        <span class=\"marquee-label\">{{ collection.title }}</span>\n      </a>\n    {% endfor %}\n  </div>\n</div>",
